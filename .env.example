# ═══════════════════════════════════════════════════════════
#  Risqué Portfolio Analytics — Environment Variables
# ═══════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit the .env file to version control!
# ═══════════════════════════════════════════════════════════

# ── AI (Groq via OpenAI-compatible API) ───────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── MongoDB (Atlas) ───────────────────────────────────────
# Get your connection string from MongoDB Atlas dashboard
MONGO_DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/risque?retryWrites=true&w=majority
# Local dev alternative:
# MONGO_DB_URI=mongodb://localhost:27017/risque

# ── Alpha Vantage (Stock Data) ────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Email / SMTP ──────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ── JWT ───────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_64_characters_long_for_production
